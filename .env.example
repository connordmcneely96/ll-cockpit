# LL Cockpit — Required Secrets
# Copy to .dev.vars for local Cloudflare Workers preview:
#   cp .env.example .dev.vars
# Then fill in all values before running: npm run preview

# Anthropic (required for all agent functionality)
ANTHROPIC_API_KEY=

# Supabase (required for auth — currently disabled, will be enabled in future sprint)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
